# ── 数据库 ──────────────────────────────────────────
POSTGRES_USER=hvc
POSTGRES_PASSWORD=hvcpassword
POSTGRES_DB=hot_video_crawler
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://hvc:hvcpassword@localhost:5432/hot_video_crawler

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 数据源（选其一作为 MVP 主力） ─────────────────────
DATA_SOURCE=mock             # mock | feigua | chanmama | crawler
FEIGUA_API_KEY=your_feigua_api_key_here
FEIGUA_BASE_URL=https://api.feigua.cn
CHANMAMA_API_KEY=your_chanmama_api_key_here
CHANMAMA_BASE_URL=https://api.chanmama.com

# ── LLM（赛道分类兜底） ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── 通知渠道 ─────────────────────────────────────────
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token
EMAIL_SMTP_HOST=smtp-mail.outlook.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=zxy1192864812@outlook.com
EMAIL_SMTP_PASSWORD=your_outlook_password_or_app_password
EMAIL_TO=recipient@example.com

# ── 应用配置 ─────────────────────────────────────────
APP_ENV=development         # development | production
LOG_LEVEL=INFO
API_PREFIX=/api/v1
